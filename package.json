{
  "name": "aws-ask-agent",
  "version": "0.1.0",
  "type": "module",
  "blocksTemplate": "react",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "aws-blocks"
  ],
  "scripts": {
    "postinstall": "patch-package",
    "typecheck": "tsc --noEmit",
    "dev:server": "tsx watch aws-blocks/scripts/server.ts",
    "dev:client": "vite",
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "sandbox": "tsx aws-blocks/scripts/sandbox.ts",
    "sandbox:destroy": "tsx -C cdk aws-blocks/scripts/sandbox-destroy.ts",
    "sandbox:console": "tsx aws-blocks/scripts/console.ts",
    "cleanup": "tsx aws-blocks/scripts/cleanup.ts",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "deploy": "tsx aws-blocks/scripts/deploy.ts",
    "reindex": "tsx aws-blocks/scripts/reindex.ts",
    "destroy": "tsx aws-blocks/scripts/destroy.ts",
    "test:e2e": "tsx -C browser test/e2e.test.ts",
    "vendorize": "blocks-vendorize"
  },
  "dependencies": {
    "@aws-blocks/blocks": "^0.2.0",
    "@aws-blocks/hosting": "^0.1.4",
    "gsap": "^3.15.0",
    "motion": "^12.42.2",
    "ogl": "^1.0.11",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.3.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "aws-cdk-lib": "^2.257.0",
    "concurrently": "^8.2.0",
    "constructs": "^10.6.0",
    "esbuild": "^0.27.1",
    "patch-package": "^8.0.1",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "blocksTemplateVersion": "0.1.0"
}
